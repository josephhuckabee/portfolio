<section class="contact contact-hero" aria-labelledby="contact-heading">
  <div class="contact-copy">
    <p class="contact-eyebrow">Let’s build something sharp.</p>
    <h1 id="contact-heading">We want to hear from you!</h1>
    <p class="contact-lede">Whether you’re inquiring about services or just have a question, we're here to help.</p>
    <div class="contact-pills" aria-hidden="true">
      <span>UX/UI</span>
      <span>Web & Apps</span>
      <span>Data</span>
      <span>Brand</span>
    </div>
  </div>

  <form class="contact-form" method="POST" action="/api/contact" name="contact" aria-label="Contact form">
    <fieldset>
      <legend>Contact Form</legend>
      <label class="sr-only" for="website">Website</label>
      <input type="text" id="website" name="website" autocomplete="off" tabindex="-1" aria-hidden="true" style="position:absolute;left:-9999px;" />

      <label for="fname">First Name</label>
      <input type="text" id="fname" name="fname" placeholder="First name" required />

      <label for="lname">Last Name</label>
      <input type="text" id="lname" name="lname" placeholder="Last name" required />

      <label for="email">Email</label>
      <input type="email" id="email" name="email" placeholder="you@example.com" required />

      <button type="submit">Submit</button>
    </fieldset>
  </form>
</section>
