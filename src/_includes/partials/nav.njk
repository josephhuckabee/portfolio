<nav role="navigation" aria-label="Main navigation">
  <ul>
    {% set base = page.url | toRoot %}
    {% for item in site.nav %}
      {% set target = base ~ (item.url | stripLeadingSlash) %}
      {% if item.url == "/" %}
        {% set target = base %}
      {% endif %}
      <li>
        <a
          href="{{ target or './' }}"
          {% if page.url == item.url %}aria-current="page"{% endif %}
        >
          {{ item.label }}
        </a>
      </li>
    {% endfor %}
  </ul>
</nav>
