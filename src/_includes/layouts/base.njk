<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  {% set canonicalUrl = canonical or (site.url + page.url) %}
  <link rel="canonical" href="{{ canonicalUrl }}">
  <meta property="og:type" content="website">
  {% if ogTitle %}
    <meta property="og:title" content="{{ ogTitle }}">
  {% else %}
    <meta property="og:title" content="{{ title }}">
  {% endif %}
  {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
  <meta property="og:url" content="{{ canonicalUrl }}">
  <meta property="og:site_name" content="{{ site.siteName }}">
  <link href="{{ baseUrl }}/assets/style.css" rel="stylesheet" type="text/css" />
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <header role="banner">
    {% include "partials/nav.njk" %}
    {% if headerImage %}
      <img src="{{ baseUrl }}/assets/{{ headerImage }}" alt="{{ headerImageAlt | default("Header image") }}">
    {% endif %}
  </header>

  <main id="main" role="main">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <script src="{{ baseUrl }}/assets/index.js"></script>
</body>
</html>
